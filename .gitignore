# ---------------------------------------------------------------------------
# notchide — .gitignore (Swift + Xcode + macOS)
# ---------------------------------------------------------------------------

# Swift Package Manager
.build/
.swiftpm/
Package.resolved
# Keep the app/ package's resolved graph out of the tree; it's machine-local.
app/.build/
app/.swiftpm/
app/Package.resolved

# Xcode / XcodeGen
# The .xcodeproj is generated by XcodeGen from project.yml — never commit it.
*.xcodeproj/
*.xcworkspace/
!default.xcworkspace/
DerivedData/
build/
*.xcuserstate
xcuserdata/
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Xcode per-user & shared scheme noise (keep intentional shared schemes only)
**/xcshareddata/WorkspaceSettings.xcsettings

# Signing / notarization artifacts
*.p12
*.provisionprofile
*.cer
notarization-*.json
*.dmg
*.pkg
*.app/

# Swift tooling caches
.swift-version
timeline.xctimeline
playground.xcworkspace

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.DocumentRevisions-V100
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Editors
.vscode/
.idea/
*.swp
*.swo
*~

# Local environment / secrets
.env
.env.local
*.local
